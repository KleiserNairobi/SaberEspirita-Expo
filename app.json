{
  "expo": {
    "name": "Saber Espírita",
    "slug": "saber-espirita",
    "scheme": "saber-espirita",
    "version": "2.0.19",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "ios": {
      "buildNumber": "54",
      "supportsTablet": false,
      "bundleIdentifier": "app.saberespirita",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification", "audio"],
        "NSLocationWhenInUseUsageDescription": "Permita sua localização em uso para receber notificações personalizadas sobre o Saber Espírita."
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": ["group.app.saberespirita.onesignal"]
      },
      "googleServicesFile": "./dev/configs/GoogleService-Info.plist"
    },
    "android": {
      "versionCode": 54,
      "predictiveBackGestureEnabled": false,
      "package": "app.saberespirita",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "com.google.android.gms.permission.AD_ID",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "googleServicesFile": "./dev/configs/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F2F7F2",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#121E31",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesGoogleServices": true
          }
        }
      ],
      [
        "./node_modules/@react-native-firebase/app/app.plugin.js",
        {
          "android": {
            "googleServicesFile": "./dev/configs/google-services.json"
          },
          "ios": {
            "googleServiceInfoPlist": "./dev/configs/GoogleService-Info.plist"
          }
        }
      ],
      "./dev/scripts/withAndroidForegroundPermissions.js",
      "./dev/plugins/withModularHeaders.js",
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "@hot-updater/react-native",
        {
          "channel": "production"
        }
      ]
    ]
  }
}
